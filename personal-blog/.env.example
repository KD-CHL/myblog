# Local development falls back to admin / admin123456. Always override these in production.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password
# Optional alternative to ADMIN_PASSWORD: scrypt$<salt>$<hash>
# ADMIN_PASSWORD_HASH=

# Required in production, at least 32 random characters.
SESSION_SECRET=replace-with-at-least-32-random-characters

# Vercel production storage. Provision Turso through the Vercel Marketplace.
# TURSO_DATABASE_URL=libsql://your-database.turso.io
# TURSO_AUTH_TOKEN=your-turso-token

# Comma-separated browser origins allowed to make credentialed requests.
# ALLOWED_ORIGINS=https://your-domain.example

# Optional local overrides.
# BLOG_DB_FILE=./apps/api/data/blog.sqlite
# MAX_BODY_BYTES=1048576
# LOG_LEVEL=debug
